# ============================================
# Plantão 360 - Environment Variables
# ============================================

# App
APP_NAME=Plantao360
APP_VERSION=1.0.0
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite:///./plantao360.db

# Security
# EM PRODUÇÃO: obrigatório definir um valor aleatório (>= 32 caracteres) — o
# startup ABORTA se ficar com este valor de exemplo. Gere um com:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production-use-a-real-secret

# Bootstrap admin (usuário criado automaticamente no primeiro startup)
# EM PRODUÇÃO: ADMIN_PASSWORD é obrigatório (>= 8 caracteres, não pode ser um
# valor padrão como "admin123") — o startup ABORTA caso contrário.
ADMIN_EMAIL=admin@plantao360.local
ADMIN_PASSWORD=admin123

# Logging
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Feature Flags
ENABLE_JWT=false
ENABLE_AUDIT_LOG=false
ENABLE_BI=false
ENABLE_ANALYTICS=false
ENABLE_TASY_INTEGRATION=false
ENABLE_EXPORT_PDF=false
ENABLE_IMPORT_LEGACY=false
DEMO_MODE=true

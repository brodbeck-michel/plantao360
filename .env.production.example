# ============================================
# Plantão 360 - Produção (MODELO — copie para .env.production e preencha)
# NUNCA versione o .env.production real (ele fica no .gitignore).
# ============================================

APP_NAME=Plantao360
APP_VERSION=1.0.0
ENVIRONMENT=production

# ---- Banco de dados (PostgreSQL) ----
# POSTGRES_PASSWORD deve ser forte e IDÊNTICO ao usado na DATABASE_URL.
# ATENÇÃO: como a senha vai dentro da DATABASE_URL, ela NÃO pode conter os
# caracteres @ : / (eles quebram o parse da URL). Se precisar usá-los, faça
# URL-encode na DATABASE_URL (ex.: @ vira %40, : vira %3A, / vira %2F).
POSTGRES_USER=plantao360
POSTGRES_PASSWORD=
POSTGRES_DB=plantao360
DATABASE_URL=postgresql+psycopg2://plantao360:SUA_SENHA_POSTGRES@db:5432/plantao360

# ---- Imagem a implantar (tag publicada no GHCR) ----
TAG=latest

# ---- Segurança ----
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Requisitos de produção: SECRET_KEY >= 32 chars; ADMIN_PASSWORD >= 8 chars (não pode ser padrão).
SECRET_KEY=
ADMIN_EMAIL=admin@seudominio.local
ADMIN_PASSWORD=

# ---- Logging ----
LOG_LEVEL=INFO

# ---- CORS (ajuste para o domínio interno em produção) ----
ALLOWED_ORIGINS=*

# ---- Feature flags ----
ENABLE_JWT=false
ENABLE_AUDIT_LOG=false
ENABLE_BI=false
ENABLE_ANALYTICS=false
ENABLE_TASY_INTEGRATION=false
ENABLE_EXPORT_PDF=false
ENABLE_IMPORT_LEGACY=false
# Produção NUNCA semeia automaticamente (seed é comando manual).
DEMO_MODE=false

# ---- Portas ----
BACKEND_PORT=8000
FRONTEND_PORT=3001

# ---- Frontend (modo MVP) ----
VITE_MVP_MODE=true

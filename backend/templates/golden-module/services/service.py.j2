from typing import Optional

from app.database.unit_of_work import UnitOfWork
from app.repositories.{{module_name_snake}}_repository import {{module_name}}Repository
from app.models.{{module_name_snake}} import {{module_name}}
from app.schemas.{{module_name_snake}}.{{module_name_snake}}_create import {{module_name}}CreateDTO
from app.schemas.{{module_name_snake}}.{{module_name_snake}}_update import {{module_name}}UpdateDTO
from app.schemas.{{module_name_snake}}.{{module_name_snake}}_response import {{module_name}}ResponseDTO
from app.schemas.{{module_name_snake}}.{{module_name_snake}}_filters import {{module_name}}FilterDTO
from app.common.pagination import Page
from app.common.result import Success, Failure, Result
from app.common.api_response import ApiResponse
from app.events.event_dispatcher import EventDispatcher, Event
from app.domain.events.event_names import DomainEventName
from app.domain.errors.{{module_name_snake}}_errors import {{module_name}}ErrorCode
from app.core.logging import get_logger

logger = get_logger("service.{{module_name_snake}}")

event_dispatcher = EventDispatcher()


class {{module_name}}Service:
    def __init__(self, uow: UnitOfWork):
        self.uow = uow

    @property
    def repo(self) -> {{module_name}}Repository:
        return {{module_name}}Repository(self.uow.session)

    def list(self, filter_dto: {{module_name}}FilterDTO) -> Page[{{module_name}}ResponseDTO]:
        skip = (filter_dto.page - 1) * filter_dto.size
        items = self.repo.search(
            skip=skip,
            limit=filter_dto.size,
            sort_by=filter_dto.sort_by,
            sort_direction=filter_dto.sort_direction,
            **filter_dto.to_filters(),
        )
        total = self.repo.count_filtered(**filter_dto.to_filters())
        dtos = [{{module_name}}ResponseDTO.model_validate(d) for d in items]
        return Page(
            items=dtos,
            page=filter_dto.page,
            size=filter_dto.size,
            total=total,
        )

    def get_by_id(self, id: int) -> Result[{{module_name}}ResponseDTO]:
        entity = self.repo.get_by_id(id)
        if not entity:
            return Failure(
                error={{module_name}}ErrorCode.{{module_name_upper}}_NOT_FOUND,
                code={{module_name}}ErrorCode.{{module_name_upper}}_NOT_FOUND,
            )
        return Success(data={{module_name}}ResponseDTO.model_validate(entity))

    def create(self, dto: {{module_name}}CreateDTO) -> Result[{{module_name}}ResponseDTO]:
        {% if unique_field %}
        if self.repo.exists_by_{{unique_field}}(dto.{{unique_field}}):
            return Failure(
                error=f"{{unique_field_label}} {{'{'}}dto.{{unique_field}}{{'}'}} já cadastrado",
                code={{module_name}}ErrorCode.{{module_name_upper}}_ALREADY_EXISTS,
            )
        {% endif %}

        entity = {{module_name}}(**dto.model_dump())
        created = self.repo.create(entity)

        event_dispatcher.dispatch(
            Event(
                name=DomainEventName.{{module_name_upper}}_CREATED_V1,
                data={"id": created.id},
            )
        )

        logger.info("{{event_prefix}}.created.v1", extra={"{{module_name_snake}}_id": created.id})
        return Success(data={{module_name}}ResponseDTO.model_validate(created))

    def update(self, id: int, dto: {{module_name}}UpdateDTO) -> Result[{{module_name}}ResponseDTO]:
        entity = self.repo.get_by_id(id)
        if not entity:
            return Failure(
                error={{module_name}}ErrorCode.{{module_name_upper}}_NOT_FOUND,
                code={{module_name}}ErrorCode.{{module_name_upper}}_NOT_FOUND,
            )

        update_data = dto.model_dump(exclude_unset=True)
        for field_name, value in update_data.items():
            setattr(entity, field_name, value)

        updated = self.repo.update(entity)

        event_dispatcher.dispatch(
            Event(
                name=DomainEventName.{{module_name_upper}}_UPDATED_V1,
                data={"id": updated.id},
            )
        )

        logger.info("{{event_prefix}}.updated.v1", extra={"{{module_name_snake}}_id": updated.id})
        return Success(data={{module_name}}ResponseDTO.model_validate(updated))

    def delete(self, id: int) -> Result[bool]:
        entity = self.repo.get_by_id(id)
        if not entity:
            return Failure(
                error={{module_name}}ErrorCode.{{module_name_upper}}_NOT_FOUND,
                code={{module_name}}ErrorCode.{{module_name_upper}}_NOT_FOUND,
            )

        self.repo.soft_delete(id)

        event_dispatcher.dispatch(
            Event(
                name=DomainEventName.{{module_name_upper}}_DEACTIVATED_V1,
                data={"id": id},
            )
        )

        logger.info("{{event_prefix}}.deactivated.v1", extra={"{{module_name_snake}}_id": id})
        return Success(data=True)

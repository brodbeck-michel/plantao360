class Test{{module_name}}ResponseContract:
    def test_success_response_structure(self):
        response = ApiResponse.ok(data={"id": 1})
        result = response.to_dict()
        assert result["success"] is True
        assert result["data"]["id"] == 1
        assert result["errors"] == []

    def test_error_response_structure(self):
        response = ApiResponse.fail_with_code(
            code={{module_name}}ErrorCode.{{module_name_upper}}_NOT_FOUND,
            message="Not found",
        )
        result = response.to_dict()
        assert result["success"] is False
        assert result["error"]["code"] == "{{module_name_upper}}_NOT_FOUND"


class Test{{module_name}}ErrorContract:
    def test_error_codes_are_strings(self):
        for code in {{module_name}}ErrorCode:
            assert isinstance(code.value, str)
            assert code.value == code.value.upper()

    def test_required_error_codes_exist(self):
        assert hasattr({{module_name}}ErrorCode, "{{module_name_upper}}_NOT_FOUND")
        assert hasattr({{module_name}}ErrorCode, "{{module_name_upper}}_ALREADY_EXISTS")
